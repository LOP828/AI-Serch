# Critical Search Layer environment variables
# Copy this file to .env and fill real values locally.
# Never commit .env to Git.

# Active app settings used by app/core/config.py.
# Settings are read with the CSL_ prefix.
CSL_APP_NAME=Critical Search Layer
CSL_APP_VERSION=0.1.0
CSL_ENVIRONMENT=development
CSL_LOG_LEVEL=INFO

# Future REST/service settings.
# These are documented placeholders for provider integration and are not
# currently consumed by the mock/static v0.1 MVP runtime.
CSL_APP_BASE_URL=http://localhost:8000
CSL_API_V1_PREFIX=/api/v1
CSL_REQUEST_TIMEOUT_SECONDS=10
CSL_MAX_SOURCES=8
CSL_MAX_DOCUMENT_CHARS=20000

# Future search provider settings.
# Current v0.1 MVP uses StaticSearchAdapter / MockSearchAdapter only.
CSL_SEARCH_PROVIDER=mock
CSL_TAVILY_API_KEY=
CSL_BRAVE_SEARCH_API_KEY=
CSL_SERPAPI_API_KEY=
CSL_BING_SEARCH_API_KEY=

# Future LLM provider settings.
# Current v0.1 MVP uses rule-based evidence extraction only.
CSL_LLM_PROVIDER=
CSL_OPENAI_API_KEY=
CSL_OPENAI_MODEL=

# Future persistence/cache settings.
# Current v0.1 MVP is stateless and does not use database or Redis.
CSL_DATABASE_URL=
CSL_REDIS_URL=
