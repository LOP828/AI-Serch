# Critical Search Layer environment variables
# Copy this file to .env and fill real values locally.
# Never commit .env to Git.

# App
APP_NAME=Critical Search Layer
APP_ENV=development
APP_DEBUG=true
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1
REQUEST_TIMEOUT_SECONDS=10
MAX_SOURCES=8
MAX_DOCUMENT_CHARS=12000

# Search provider
# MVP recommendation: tavily
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=

# LLM provider
# First phase should not call LLM.
# Later evidence extraction may use an LLM provider.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Reliability defaults
DEFAULT_STRICTNESS=balanced
REQUIRE_PRIMARY_SOURCE=false
RETURN_RAW_EVIDENCE=true

# Database
# MVP can run without database.
DATABASE_URL=

# Redis
# MVP can run without Redis.
REDIS_URL=
